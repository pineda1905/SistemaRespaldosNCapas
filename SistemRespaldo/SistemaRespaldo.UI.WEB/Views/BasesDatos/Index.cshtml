@model IEnumerable<SistemaRespaldo.EN.BaseDatos>

@{
    ViewData["Title"] = "Gestión de Bases de Datos";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12 text-center">
            <h2 class="text-primary fw-bold border-bottom pb-3">📂 Panel de Control - Bases de Datos</h2>
            <p class="text-muted">Configura las reglas de respaldo para cada base de datos en MySQL.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 border-top border-primary border-5">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-dark">⚙️ Nueva Configuración</h5>
                </div>
                <div class="card-body">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger mb-3">
                            <strong>⚠️ Error:</strong> @TempData["Error"]
                        </div>
                    }
                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success mb-3">
                            <strong>✅ ¡Éxito!</strong> @TempData["Mensaje"]
                        </div>
                    }

                    <form asp-action="Guardar" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Nombre de la Base de Datos</label>
                            <input type="text" name="nombreBaseDatos" class="form-control" placeholder="Ej: campanaoficial" required autocomplete="off" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Tipo de Respaldo</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="tipoRespaldo" value="Completo" id="tipoComp" checked>
                                <label class="form-check-label" for="tipoComp">
                                    Respaldo Completo
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="tipoRespaldo" value="Parcial" id="tipoParc">
                                <label class="form-check-label" for="tipoParc">
                                    Respaldo Parcial (Reducido)
                                </label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Tablas a Ignorar (Opcional)</label>
                            <input type="text" name="tablasIgnorar" class="form-control" placeholder="Ej: logs,error,temp" />
                            <small class="text-muted d-block mt-1">Separar nombres por comas.</small>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm py-2 mt-2">
                            🚀 Agregar a Monitoreo
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">📋 Bases de Datos Configuradas</h5>
                    <span class="badge bg-info text-dark">Total: @(Model?.Count() ?? 0)</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">ID</th>
                                    <th>Nombre de Base</th>
                                    <th>Tipo</th>
                                    <th>Tablas Omitidas</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model == null || !Model.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">
                                            <i class="bi bi-info-circle d-block fs-2 mb-2"></i>
                                            Aún no has configurado bases de datos para respaldos.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var db in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 text-muted small">#@db.Id</td>
                                            <td><span class="fw-bold">@db.Nombre</span></td>
                                            <td>
                                                @if (db.EsCompleto)
                                                {
                                                    <span class="badge rounded-pill bg-success px-3">Completo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge rounded-pill bg-warning text-dark px-3">Parcial</span>
                                                }
                                            </td>
                                            <td>
                                                <small class="text-muted font-monospace">
                                                    @(string.IsNullOrEmpty(db.TablasAIgnorar) ? "---" : db.TablasAIgnorar)
                                                </small>
                                            </td>
                                            <td class="text-center">
                                                <a asp-action="Eliminar" asp-route-id="@db.Id" 
                                                   class="btn btn-outline-danger btn-sm"
                                                   onclick="return confirm('¿Estás seguro de eliminar @db.Nombre?')">
                                                   🗑️ Borrar
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>