@model IEnumerable<SistemaRespaldo.EN.BaseDatos>

@{
    ViewData["Title"] = "Gestión de Bases de Datos";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-dark border-bottom pb-2">📂 Panel de Control - Bases de Datos</h2>
            <p class="text-muted">Configura aquí las bases de datos de MySQL que el motor de Pineda respaldará automáticamente.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 m-0"><i class="bi bi-plus-circle"></i> Registrar Nueva Base</h5>
                </div>
                <div class="card-body">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger shadow-sm">
                            <strong>⚠️ Error:</strong> @TempData["Error"]
                        </div>
                    }
                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success shadow-sm">
                            <strong>✅ ¡Éxito!</strong> @TempData["Mensaje"]
                        </div>
                    }

                    <form asp-action="Guardar" method="post">
                        <div class="mb-3">
                            <label class="form-label text-secondary fw-bold">Nombre de la Base de Datos</label>
                            <input type="text" name="nombreBaseDatos" class="form-control form-control-lg" placeholder="Ej: mi_negocio_db" required autocomplete="off" />
                        </div>
                        <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm">Agregar a Monitoreo</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 m-0"><i class="bi bi-database"></i> Bases de Datos Registradas</h5>
                </div>
                <div class="card-body p-0">
                    @if (ViewBag.Error != null)
                    {
                        <div class="p-3">
                            <div class="alert alert-danger mb-0">@ViewBag.Error</div>
                        </div>
                    }
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" style="width: 150px;">ID MySQL</th>
                                <th>Nombre de Base de Datos</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="2" class="text-center py-4 text-muted">
                                        <i class="bi bi-info-circle fs-4 d-block mb-2"></i>
                                        Aún no hay bases de datos configuradas para respaldos.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var db in Model)
                                {
                                    <tr>
                                        <td class="ps-4 text-muted"># @db.Id</td>
                                        <td><strong>@db.Nombre</strong></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>