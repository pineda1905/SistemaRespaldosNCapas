@{
    ViewData["Title"] = "Configurar Horario de Respaldo";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">Programar Nuevo Respaldo</h4>
                </div>
                <div class="card-body">
                    
                    <!-- Aquí mostramos los mensajes de éxito o error que mandamos desde TempData en el Controlador -->
                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success">@TempData["Mensaje"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <!-- El formulario que envía la hora ingresada al método GuardarHorario del Controlador -->
                    <form asp-controller="Respaldos" asp-action="GuardarHorario" method="post">
                        
                        <div class="form-group mb-3">
                            <label for="horaRespaldo" class="form-label">Seleccione la hora (Formato 24h):</label>
                            <!-- El input type="time" muestra un reloj nativo en el navegador para elegir la hora -->
                            <input type="time" class="form-control" id="horaRespaldo" name="horaRespaldo" required />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Guardar Horario</button>
                        </div>
                        
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
@model IEnumerable<SistemaRespaldo.EN.HistorialLog>

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between">
        <h5 class="mb-0">📊 Historial Reciente de Respaldos</h5>
        <a href="javascript:location.reload()" class="btn btn-sm btn-outline-light">Actualizar</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Base de Datos</th>
                    <th>Estado</th>
                    <th>Fecha y Mensaje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model) {
                    <tr>
                        <td><strong>@log.BaseDeDatos</strong></td>
                        <td>
                            @if(log.Estado == "Exito") {
                                <span class="badge bg-success">Copiado ✅</span>
                            } else {
                                <span class="badge bg-danger">Falló ❌</span>
                            }
                        </td>
                        <td>
                            <small class="text-muted d-block">Mensaje: @log.Mensaje</small>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>